      "name": "숙성",
      "description": "발효가 끝난 맥주를 차갑게 보관하여 맛을 깔끔하게 다듬고 불순물을 가라앉힙니다.",
      "params": [
        { "key": "condition_days", "label": "숙성 일수", "type": "number", "unit": "일", "default": 7, "min": 3, "max": 21, "step": 1 }
