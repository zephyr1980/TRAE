      "description": "효모를 넣고 기다립니다. 당분이 알코올과 탄산으로 변하며 진짜 맥주가 되는 마법 같은 시간입니다.",
      "params": [
        { "key": "ferm_temp_c", "label": "발효 온도", "type": "number", "unit": "°C", "default": 18, "min": 15, "max": 25, "step": 0.5 },
